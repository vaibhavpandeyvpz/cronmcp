{
  "name": "cronmcp",
  "version": "0.3.1",
  "description": "TypeScript stdio MCP server for managing local cron prompts.",
  "type": "module",
  "bin": {
    "cronmcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-instructions.mjs",
    "clean": "rm -rf dist",
    "dev": "tsx src/index.ts",
    "prepack": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "cron",
    "scheduler",
    "cli",
    "typescript"
  ],
  "author": "Vaibhav Pandey <contact@vaibhavpandey.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vaibhavpandeyvpz/cronmcp.git"
  },
  "bugs": {
    "url": "https://github.com/vaibhavpandeyvpz/cronmcp/issues"
  },
  "homepage": "https://github.com/vaibhavpandeyvpz/cronmcp#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^14.0.3",
    "cron": "^4.4.0",
    "cron-parser": "^5.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
